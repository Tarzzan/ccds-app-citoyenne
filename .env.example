# ─────────────────────────────────────────────────────────────
# CCDS Citoyen — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ─────────────────────────────────────────────────────────────

# Base de données
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ccds_db
DB_USER=ccds_user
DB_PASS=ccds_pass_change_me

# MySQL root (Docker uniquement)
MYSQL_ROOT_PASSWORD=rootpass_change_me

# Sécurité JWT
JWT_SECRET=change_me_with_a_long_random_string_at_least_32_chars

# Environnement (development | production | testing)
APP_ENV=development

# WebSocket
WS_PORT=8081
