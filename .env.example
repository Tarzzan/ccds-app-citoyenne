# =============================================================================
# Ma Commune — Fichier de configuration d'environnement
# =============================================================================
# INSTRUCTIONS :
#   1. Copiez ce fichier : cp .env.example .env
#   2. Renseignez toutes les valeurs marquées CHANGE_ME
#   3. Ne commitez JAMAIS le fichier .env sur Git
# =============================================================================

# IDENTITE DE L'APPLICATION
# Personnalisez ces valeurs pour votre commune
APP_NAME=Ma Commune
APP_SHORT_NAME=MaCommune
APP_SLUG=ma_commune
APP_SUBTITLE=Votre commune - Administration
APP_REFERENCE_PREFIX=MC
APP_VERSION=1.2.0

# URLS ET DOMAINES
APP_URL=https://votre-domaine.com
APP_EMAIL_FROM=noreply@votre-domaine.com
CORS_ORIGINS=https://votre-domaine.com

# BASE DE DONNEES
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ma_commune_db
DB_USER=ma_commune_user
DB_PASS=CHANGE_ME_MOT_DE_PASSE_DB

# SECURITE
# Generez un secret fort : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENEREZ_UN_SECRET_FORT_AVEC_openssl_rand_base64_64

# ENVIRONNEMENT
APP_ENV=production
APP_DEBUG=false

# APPLICATION MOBILE (Expo)
# Ces variables sont utilisees lors du build de l'application mobile
EXPO_PUBLIC_API_URL=https://votre-domaine.com/api
EXPO_PUBLIC_APP_URL=https://votre-domaine.com
EXPO_PUBLIC_APP_NAME=Ma Commune
EXPO_PUBLIC_APP_SLUG=ma_commune

# DOCKER (optionnel, si deploiement via Docker Compose)
MYSQL_ROOT_PASSWORD=CHANGE_ME_MOT_DE_PASSE_ROOT_MYSQL
