{
  "expo": {
    "name": "Ma Commune Guyane",
    "slug": "ma-commune-guyane",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f4c2a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.netetfix.macommune",
      "infoPlist": {
        "NSCameraUsageDescription": "CCDS a besoin d'acc\u00e9der \u00e0 votre cam\u00e9ra pour photographier les anomalies \u00e0 signaler.",
        "NSPhotoLibraryUsageDescription": "CCDS a besoin d'acc\u00e9der \u00e0 vos photos pour joindre une image \u00e0 votre signalement.",
        "NSLocationWhenInUseUsageDescription": "CCDS utilise votre position pour localiser pr\u00e9cis\u00e9ment les anomalies que vous signalez."
      },
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f4c2a"
      },
      "package": "com.netetfix.macommune",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "CCDS a besoin d'acc\u00e9der \u00e0 votre cam\u00e9ra pour photographier les anomalies."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CCDS utilise votre position pour localiser vos signalements."
        }
      ],
      "./plugins/withKotlinVersion.js"
    ],
    "scheme": "ccds",
    "extra": {
      "API_BASE_URL": "https://votre-domaine.com/api",
      "APP_TERRITORY": "Kourou, Sinnamary, Iracoubo, Saint-\u00c9lie",
      "APP_REGION": "Guyane Fran\u00e7aise",
      "eas": {
        "projectId": "b3d38760-9ace-47eb-b84f-37419e550824"
      }
    },
    "sdkVersion": "54.0.0",
    "owner": "william.meri",
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/a7334d51-b12a-46eb-bc2d-c9b847551f66"
    }
  }
}