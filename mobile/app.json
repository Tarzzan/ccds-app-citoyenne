{
  "expo": {
    "name": "CCDS Citoyen",
    "slug": "ccds-app-citoyenne",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f4c2a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ccds.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CCDS a besoin d'accéder à votre caméra pour photographier les anomalies à signaler.",
        "NSPhotoLibraryUsageDescription": "CCDS a besoin d'accéder à vos photos pour joindre une image à votre signalement.",
        "NSLocationWhenInUseUsageDescription": "CCDS utilise votre position pour localiser précisément les anomalies que vous signalez."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f4c2a"
      },
      "package": "com.ccds.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "CCDS a besoin d'accéder à votre caméra pour photographier les anomalies."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CCDS utilise votre position pour localiser vos signalements."
        }
      ],
      "./plugins/withKotlinVersion.js"
    ],
    "scheme": "ccds",
    "extra": {
      "API_BASE_URL": "https://votre-domaine.com/api",
      "APP_TERRITORY": "Kourou, Sinnamary, Iracoubo, Saint-Élie",
      "APP_REGION": "Guyane Française",
      "eas": {
        "projectId": "a7334d51-b12a-46eb-bc2d-c9b847551f66"
      }
    },
    "sdkVersion": "54.0.0",
    "owner": "william.meri",
    "runtimeVersion": "exposdk:54.0.0",
    "updates": {
      "url": "https://u.expo.dev/a7334d51-b12a-46eb-bc2d-c9b847551f66"
    }
  }
}